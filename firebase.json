{
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**", "DEPLOY.md"],
    "rewrites": [{ "source": "/", "destination": "/login.html" }],
    "headers": [
      {
        "source": "**/*.@(html|js)",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "**/*.css",
        "headers": [{ "key": "Cache-Control", "value": "max-age=3600" }]
      }
    ]
  }
}
